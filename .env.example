# ---------------------------------------------------------------------------
# .env.example — optional environment variables for FedAgent.
#
# Copy to .env and fill in as needed:  cp .env.example .env
# (.env is gitignored.)
# ---------------------------------------------------------------------------

# Weights & Biases is REMOVED in this release. No W&B account, entity, or API
# key is required or used — runs log to the console only. (Intentionally no
# WANDB_* variables here.)

# Optional: HuggingFace token, only if a gated model/dataset download requires
# authentication during setup / download_data.sh. Leave blank otherwise.
HF_TOKEN=

# Optional: override the data download location used by download_data.sh.
# DATA_ROOT=/path/to/fedagent/data
