# ---------------------------------------------------------------------------
# paths.yaml.example — machine-specific path template for FedAgent.
#
# Copy this file to config/paths.yaml and edit the values for your machine:
#     cp config/paths.yaml.example config/paths.yaml
#
# NOTE: config/paths.yaml is read by several modules and shell scripts the
# moment a federated run starts (the federated server, the client runner,
# script_builder, partition_strategy, fed_env_manager, and the eval/run
# launchers), so a valid copy MUST exist before running anything from the
# repository root. Only placeholders appear here — no real machine paths,
# no secrets.
#
# Key layout consumed by the code (do not flatten these — the readers index
# the nested mappings exactly as shown):
#   project_root        -> paths['project_root']
#                          (resolve_paths.py, client_runner.py, script_builder.py,
#                           partition_strategy.py, fed_env_manager.py, eval/*.sh,
#                           scripts/verl-agent/**/run_*.sh)
#   config.root         -> paths['config']['root']
#                          (resolve_paths.py, custom_fed_server.py)
#   output.root         -> paths['output']['root']
#                          (resolve_paths.py)
#   repo.verl_agent     -> paths['repo']['verl_agent']
#                          (eval/eval_webshop.sh, eval/eval_alfworld.sh,
#                           scripts/verl-agent/{grpo,ppo}/run_*.sh)
#
# Data / output subdirectories are NOT separate keys: the code derives them
# from project_root at runtime (e.g. ${project_root}/data/verl-agent,
# ${project_root}/output/inference). Only the four keys above are read.
# ---------------------------------------------------------------------------

# Absolute path to this repository checkout.
project_root: /path/to/fedagent

# Where the federated verl config files live (resolve_paths.py joins
# <config.root>/<name>.yaml; custom_fed_server.py joins
# <config.root>/federated_verl_config.yaml). Normally the repo's config/ dir.
config:
  root: /path/to/fedagent/config

# Where training checkpoints and metrics are written
# (resolve_paths.py builds OUTPUT_DIR under <output.root>).
output:
  root: /path/to/fedagent/output

# Path to the vendored verl-agent framework. The eval/run launchers `cd` into
# this directory before invoking verl, so it must be an absolute path
# (usually <project_root>/third_party/verl-agent).
repo:
  verl_agent: /path/to/fedagent/third_party/verl-agent
